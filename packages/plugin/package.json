{
  "name": "better-auth-mercadopago",
  "version": "3.0.0",
  "description": "MercadoPago plugin for Better Auth — subscriptions, payments & webhooks out of the box",
  "keywords": [
    "auth",
    "better-auth",
    "mercadopago",
    "nextjs",
    "payments",
    "plugin",
    "react",
    "subscriptions",
    "webhooks"
  ],
  "homepage": "https://better-auth-mercadopago.vercel.app",
  "bugs": {
    "url": "https://github.com/IvanTsxx/better-auth-mercadopago/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IvanTsxx/better-auth-mercadopago.git",
    "directory": "packages/plugin"
  },
  "files": [
    "dist",
    "README.md",
    "README.es.md",
    "CHANGELOG.md",
    "LICENSE",
    "DISCLAIMER.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client-plugin.d.ts",
      "import": "./dist/client-plugin.js",
      "require": "./dist/client-plugin.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js",
      "require": "./dist/schemas.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@mercadopago/sdk-js": "^0.0.3",
    "mercadopago": "^2.3.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@better-fetch/fetch": "^1.1.0",
    "@prisma/client": "^5.0.0",
    "better-auth": "^1.5.0",
    "zod": "^4.1.0"
  },
  "peerDependenciesMeta": {
    "@better-fetch/fetch": {
      "optional": false
    },
    "@prisma/client": {
      "optional": false
    },
    "better-auth": {
      "optional": false
    },
    "zod": {
      "optional": false
    }
  }
}

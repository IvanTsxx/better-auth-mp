{
  "name": "better-auth-mp",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@prisma/client": "^7.4.2",
      "better-auth": "^1.5.1",
      "@better-fetch/fetch": "^1.1.21"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @repo/db db:push",
    "db:studio": "turbo -F @repo/db db:studio",
    "db:generate": "turbo -F @repo/db db:generate",
    "db:migrate": "turbo -F @repo/db db:migrate",
    "db:start": "turbo -F @repo/db db:start",
    "db:watch": "turbo -F @repo/db db:watch",
    "db:stop": "turbo -F @repo/db db:stop",
    "db:down": "turbo -F @repo/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "turbo run build --filter=better-auth-mp && changeset publish"
  },
  "dependencies": {
    "@repo/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@repo/config": "workspace:*",
    "@types/node": "^22.13.14",
    "better-auth-mp": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsup": "^8.5.1",
    "turbo": "^2.6.3",
    "typescript": "catalog:",
    "ultracite": "7.2.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.10"
}

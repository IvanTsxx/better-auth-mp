{
  "name": "better-auth-mercadopago",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@prisma/client": "^7.4.2",
      "better-auth": "^1.5.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @better-auth-mercadopago/db db:push",
    "db:studio": "turbo -F @better-auth-mercadopago/db db:studio",
    "db:generate": "turbo -F @better-auth-mercadopago/db db:generate",
    "db:migrate": "turbo -F @better-auth-mercadopago/db db:migrate",
    "db:start": "turbo -F @better-auth-mercadopago/db db:start",
    "db:watch": "turbo -F @better-auth-mercadopago/db db:watch",
    "db:stop": "turbo -F @better-auth-mercadopago/db db:stop",
    "db:down": "turbo -F @better-auth-mercadopago/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@better-auth-mercadopago/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth-mercadopago/config": "workspace:*",
    "@types/node": "^22.13.14",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.6.3",
    "typescript": "catalog:",
    "ultracite": "7.2.5"
  },
  "packageManager": "bun@1.3.10"
}
